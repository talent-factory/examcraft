@startuml ExamCraft_Deployment
!theme plain
skinparam defaultTextAlignment center
title ExamCraft AI - Deployment Architecture

node "Development Environment" {
  node "Docker Host" as docker_host {
    component "nginx" as nginx_dev {
      portin "80" as port80
      portin "443" as port443
    }

    component "Frontend Container" as frontend_dev {
      portin "3000" as port3000
      artifact "React App" as react_app
    }

    component "Backend Container" as backend_dev {
      portin "8000" as port8000
      artifact "FastAPI App" as fastapi_app
    }

    database "PostgreSQL Container" as postgres_dev {
      portin "5432" as port5432
      database "examcraft_dev" as db_dev
    }

    database "Redis Container" as redis_dev {
      portin "6379" as port6379
      database "Cache Store" as cache_dev
    }

    folder "Shared Volumes" as volumes_dev {
      folder "uploads/"
      folder "vector_db/"
      folder "logs/"
    }
  }
}

node "Production Environment" {
  node "Load Balancer" as lb {
    component "nginx/HAProxy"
  }

  node "Application Cluster" {
    node "App Server 1" as app1 {
      component "Frontend" as frontend_prod1
      component "Backend" as backend_prod1
    }

    node "App Server 2" as app2 {
      component "Frontend" as frontend_prod2
      component "Backend" as backend_prod2
    }
  }

  node "Database Cluster" {
    node "Primary DB" as db_primary {
      database "PostgreSQL Primary"
    }

    node "Replica DB" as db_replica {
      database "PostgreSQL Replica"
    }
  }

  node "Cache Cluster" {
    node "Redis Cluster" as redis_cluster {
      database "Redis Node 1"
      database "Redis Node 2"
      database "Redis Node 3"
    }
  }

  node "Storage" {
    cloud "Object Storage" as s3 {
      folder "documents/"
      folder "exports/"
      folder "backups/"
    }

    node "Vector DB" as vector_prod {
      database "ChromaDB Cluster"
    }
  }
}

cloud "External Services" as external {
  cloud "Claude API" as claude_api
  cloud "Monitoring" as monitoring
  cloud "CI/CD" as cicd
}

' Development connections
nginx_dev --> frontend_dev : reverse proxy
nginx_dev --> backend_dev : reverse proxy
backend_dev --> postgres_dev : database
backend_dev --> redis_dev : cache
backend_dev --> volumes_dev : file storage

' Production connections
lb --> app1 : load balance
lb --> app2 : load balance
app1 --> db_primary : read/write
app2 --> db_primary : read/write
app1 --> db_replica : read only
app2 --> db_replica : read only
app1 --> redis_cluster : cache
app2 --> redis_cluster : cache
app1 --> s3 : file storage
app2 --> s3 : file storage
app1 --> vector_prod : vector search
app2 --> vector_prod : vector search

' External services
backend_dev --> claude_api : AI generation
backend_prod1 --> claude_api : AI generation
backend_prod2 --> claude_api : AI generation
lb --> monitoring : metrics
cicd --> app1 : deployment
cicd --> app2 : deployment

note right of volumes_dev
  Development uses
  local volumes for
  fast iteration
end note

note right of s3
  Production uses
  cloud storage for
  scalability and
  disaster recovery
end note

note bottom of claude_api
  Rate limiting and
  cost optimization
  implemented in
  both environments
end note

@enduml
