graph TB
    %% Titel
    title[ExamCraft AI - System Architecture]
    style title fill:none,stroke:none

    %% Pakete und Komponenten definieren
    subgraph Frontend["Frontend Layer"]
        frontend["React App"]
        frontend --> frontendItems["Document Upload<br>Question Generator<br>Exam Viewer<br>Document Manager"]
        style frontendItems fill:none,stroke:none
    end

    subgraph API["API Gateway"]
        api["FastAPI Backend"]
        api --> apiItems["/api/v1/documents<br>/api/v1/questions<br>/api/v1/generate<br>/health"]
        style apiItems fill:none,stroke:none
    end

    subgraph Services["Service Layer"]
        docservice["Document Service"]
        docservice --> docserviceItems["upload_document()<br>process_document()<br>get_documents()"]
        style docserviceItems fill:none,stroke:none

        docling["Docling Service"]
        docling --> doclingItems["process_pdf()<br>extract_content()<br>create_chunks()"]
        style doclingItems fill:none,stroke:none

        vectorsvc["Vector Service"]
        vectorsvc --> vectorsvcItems["add_embeddings()<br>similarity_search()<br>manage_collections()"]
        style vectorsvcItems fill:none,stroke:none

        ragsvc["RAG Service"]
        ragsvc --> ragsvcItems["generate_questions()<br>retrieve_context()<br>build_prompts()"]
        style ragsvcItems fill:none,stroke:none

        claudesvc["Claude Service"]
        claudesvc --> claudesvcItems["generate_with_context()<br>validate_response()<br>handle_rate_limits()"]
        style claudesvcItems fill:none,stroke:none
    end

    subgraph Data["Data Layer"]
        postgres[(PostgreSQL)]
        postgres --> postgresItems["documents<br>questions<br>users<br>metadata"]
        style postgresItems fill:none,stroke:none

        redis[(Redis)]
        redis --> redisItems["session_cache<br>api_cache<br>rate_limits"]
        style redisItems fill:none,stroke:none

        chroma[(ChromaDB)]
        chroma --> chromaItems["document_embeddings<br>vector_collections<br>similarity_index"]
        style chromaItems fill:none,stroke:none
    end

    subgraph External["External Services"]
        claude["Claude API"]
        claude --> claudeItems["Sonnet 3.5<br>Question Generation<br>Text Analysis"]
        style claudeItems fill:none,stroke:none

        %% Notiz für Claude
        claudeNote["Rate Limited<br>Cost Optimized<br>Fallback Available"]
        claude --- claudeNote
        style claudeNote fill:#f9f,stroke:#333,stroke-dasharray: 5 5
    end

    subgraph Storage["Storage"]
        storage["File Storage"]
        storage --> storageItems["uploads/<br>processed/<br>cache/"]
        style storageItems fill:none,stroke:none
    end

    %% Verbindungen
    frontend -- "HTTP/REST" --> api
    api -- "Service calls" --> docservice
    api -- "Service calls" --> ragsvc

    docservice -- "Document processing" --> docling
    docservice -- "File operations" --> storage
    docservice -- "Metadata storage" --> postgres

    docling -- "Embedding creation" --> vectorsvc
    vectorsvc -- "Vector operations" --> chroma

    ragsvc -- "Context retrieval" --> vectorsvc
    ragsvc -- "AI generation" --> claudesvc
    claudesvc -- "API calls" --> claude

    api -- "Caching" --> redis
    api -- "Data persistence" --> postgres

    %% Notiz für ChromaDB
    chromaNote["Local Deployment<br>Fast Similarity Search<br>Persistent Storage"]
    chroma --- chromaNote
    style chromaNote fill:#f9f,stroke:#333,stroke-dasharray: 5 5
