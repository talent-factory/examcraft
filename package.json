{
  "name": "examcraft-monorepo",
  "version": "1.0.0",
  "private": true,
  "description": "ExamCraft AI - NPM Workspace Monorepo",
  "workspaces": [
    "packages/core/frontend",
    "packages/premium/frontend",
    "packages/enterprise/frontend"
  ],
  "scripts": {
    "install:all": "npm install",
    "build:core": "npm run build --workspace=@examcraft/core",
    "build:premium": "npm run build --workspace=@examcraft/premium",
    "build:enterprise": "npm run build --workspace=@examcraft/enterprise",
    "build:all": "npm run build:core && npm run build:premium && npm run build:enterprise",
    "test:core": "npm test --workspace=@examcraft/core",
    "test:premium": "npm test --workspace=@examcraft/premium",
    "test:enterprise": "npm test --workspace=@examcraft/enterprise",
    "test:all": "npm test --workspaces",
    "dev:core": "npm run dev --workspace=@examcraft/core",
    "dev:premium": "npm run dev --workspace=@examcraft/premium",
    "dev:enterprise": "npm run dev --workspace=@examcraft/enterprise",
    "lint": "npm run lint --workspaces",
    "clean": "npm run clean --workspaces && rm -rf node_modules"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "^5.3.0",
    "eslint": "^8.56.0",
    "prettier": "^3.1.0",
    "turbo": "^1.11.0"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  }
}
