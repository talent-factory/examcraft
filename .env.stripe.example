# Stripe Payment Integration Configuration
#
# Copy these lines to your .env file and replace with your actual values
# Get your keys from: https://dashboard.stripe.com/test/apikeys

# ============================================
# Stripe API Keys
# ============================================

# Stripe Secret Key (Backend)
# Get from: https://dashboard.stripe.com/test/apikeys
# Format: sk_test_<KEY> (test mode) or sk_live_<KEY> (production)
STRIPE_SECRET_KEY=<YOUR_STRIPE_SECRET_KEY>

# Stripe Webhook Signing Secret (Backend)
# For local development: Get from `stripe listen` command output
# For production: Get from https://dashboard.stripe.com/webhooks after creating endpoint
# Format: whsec_<SECRET>
STRIPE_WEBHOOK_SECRET=<YOUR_STRIPE_WEBHOOK_SECRET>

# ============================================
# Stripe Price IDs (Frontend)
# ============================================

# Starter Plan Price ID
# Get from: https://dashboard.stripe.com/test/products (click on your Starter product)
# Format: price_...
REACT_APP_STRIPE_PRICE_STARTER=price_your_starter_price_id_here

# Professional Plan Price ID
# Get from: https://dashboard.stripe.com/test/products (click on your Professional product)
# Format: price_...
REACT_APP_STRIPE_PRICE_PROFESSIONAL=price_your_professional_price_id_here

# ============================================
# Setup Instructions
# ============================================
#
# 1. Create products in Stripe Dashboard:
#    https://dashboard.stripe.com/test/products
#
#    Starter Plan:
#    - Name: ExamCraft Starter
#    - Price: €19.00 EUR / month
#    - Billing: Recurring / Monthly
#
#    Professional Plan:
#    - Name: ExamCraft Professional
#    - Price: €149.00 EUR / month
#    - Billing: Recurring / Monthly
#
# 2. Copy Secret Key from:
#    https://dashboard.stripe.com/test/apikeys
#
# 3. For local testing, run:
#    ./scripts/stripe-webhook-test.sh
#    Copy the webhook secret from the output
#
# 4. For production, create webhook endpoint:
#    https://dashboard.stripe.com/webhooks
#    URL: https://your-domain.com/api/v1/webhooks/stripe
#    Events:
#      - checkout.session.completed
#      - customer.subscription.updated
#      - customer.subscription.deleted
#
# 5. Restart your backend:
#    docker compose --env-file .env -f docker-compose.full.yml restart backend
#
# For detailed setup instructions, see:
# - Quick Start: STRIPE_QUICKSTART.md
# - Full Guide: STRIPE_SETUP_GUIDE.md
