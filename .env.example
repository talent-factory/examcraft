# ExamCraft AI Environment Configuration

# ============================================================================
# DOCKER COMPOSE - PORT CONFIGURATION (for Git Worktrees)
# ============================================================================
#
# When using Git Worktrees for parallel development, each worktree needs
# unique ports to avoid conflicts. Use these variables to configure ports
# per worktree.
#
# Default values (main branch):
#   FRONTEND_PORT=3000
#   BACKEND_PORT=8000
#
# Example for feature branch worktree:
#   FRONTEND_PORT=3001
#   BACKEND_PORT=8001
#
# Note: PostgreSQL, Redis, and Qdrant are shared across all worktrees
#       to avoid database duplication and keep setup simple.

FRONTEND_PORT=3000
BACKEND_PORT=8000

# ============================================================================
# Claude API Configuration
CLAUDE_API_KEY=your_claude_api_key_here
CLAUDE_MODEL=claude-3-5-sonnet-20241022
CLAUDE_MAX_RPM=50
CLAUDE_MAX_TOKENS=4000
CLAUDE_MAX_RETRIES=3
CLAUDE_RETRY_DELAY=1.0
CLAUDE_DEMO_MODE=false

# Database Configuration
DATABASE_URL=postgresql://examcraft:examcraft_dev@localhost:5432/examcraft
REDIS_URL=redis://localhost:6379

# Application Configuration
ENVIRONMENT=development
DEBUG=true

# Document Processing Configuration
# Options: "docling" (recommended), "legacy", "auto" (tries docling, falls back to legacy)
DOCUMENT_PROCESSOR_TYPE=docling

# Frontend Configuration
REACT_APP_API_URL=http://localhost:8000
REACT_APP_ENVIRONMENT=development

# Security
SECRET_KEY=your_secret_key_here_change_in_production

# Google OAuth Configuration
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here