# ExamCraft AI Environment Configuration

# ============================================================================
# DOCKER COMPOSE - PORT CONFIGURATION (for Git Worktrees)
# ============================================================================
#
# When using Git Worktrees for parallel development, each worktree needs
# unique ports to avoid conflicts. Use these variables to configure ports
# per worktree.
#
# Default values (main branch):
#   FRONTEND_PORT=3000
#   BACKEND_PORT=8000
#
# Example for feature branch worktree:
#   FRONTEND_PORT=3001
#   BACKEND_PORT=8001
#
# Note: PostgreSQL, Redis, and Qdrant are shared across all worktrees
#       to avoid database duplication and keep setup simple.

FRONTEND_PORT=3000
BACKEND_PORT=8000

# ============================================================================
# Claude API Configuration
CLAUDE_API_KEY=your_claude_api_key_here
CLAUDE_MODEL=claude-3-5-sonnet-20241022
CLAUDE_MAX_RPM=50
CLAUDE_MAX_TOKENS=4000
CLAUDE_MAX_RETRIES=3
CLAUDE_RETRY_DELAY=1.0
CLAUDE_DEMO_MODE=false

# OpenAI API Configuration
OPENAI_API_KEY=sk-proj-your-key
EMBEDDING_MODEL=text-embedding-3-small # OpenAI Model (default)

# Database Configuration
DATABASE_URL=postgresql://examcraft:examcraft_dev@localhost:5432/examcraft
REDIS_URL=redis://localhost:6379

# RabbitMQ Configuration (for async document processing with Celery)
RABBITMQ_USER=examcraft
RABBITMQ_PASSWORD=<change_in_production>

# Celery Configuration
CELERY_BROKER_URL=amqp://examcraft:<change_in_production>@rabbitmq:5672/
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# Application Configuration
ENVIRONMENT=development
DEBUG=true

# Document Processing Configuration
# Options: "pymupdf" (default, fast), "docling" (deprecated, slow), "legacy", "auto"
# Default: pymupdf (no configuration needed)
# DOCUMENT_PROCESSOR_TYPE=pymupdf

# Frontend Configuration
REACT_APP_API_URL=http://localhost:8000
REACT_APP_ENVIRONMENT=development

# Security
SECRET_KEY=your_secret_key_here_change_in_production

# Google OAuth Configuration
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here

# Resend Email Configuration
RESEND_API_KEY=re_your_resend_api_key_here
RESEND_FROM_EMAIL=noreply@examcraft.ai
RESEND_FROM_NAME=ExamCraft AI
RESEND_WEBHOOK_SECRET=whsec_your_webhook_secret_here

# Sentry Configuration (Error Tracking & Performance Monitoring)
# Get your DSNs from: https://talent-factory.sentry.io/
SENTRY_DSN=https://YOUR_BACKEND_DSN@o4509606849019904.ingest.de.sentry.io/YOUR_PROJECT_ID
REACT_APP_SENTRY_DSN=https://YOUR_FRONTEND_DSN@o4509606849019904.ingest.de.sentry.io/YOUR_PROJECT_ID
ENABLE_SENTRY=false
REACT_APP_ENABLE_SENTRY=false
APP_VERSION=1.0.0-dev
REACT_APP_VERSION=1.0.0-dev
# Frontend Deployment Mode
REACT_APP_DEPLOYMENT_MODE=full

# ============================================================================
# MCP (Model Context Protocol) Configuration
# ============================================================================
# Claude Code MCP Server Configuration
# These API keys are required for MCP integrations

# Anthropic API Key (for Task Master AI)
ANTHROPIC_API_KEY=sk-ant-api03-your_anthropic_api_key_here

# Linear API Key (for Linear Issue Management)
# Get your API key from: https://linear.app/settings/api
LINEAR_API_KEY=lin_api_your_linear_api_key_here
