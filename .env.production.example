# ExamCraft AI - Production Environment Configuration
# Für Render.com Deployment

# ============================================
# BACKEND CONFIGURATION
# ============================================

# Environment
ENVIRONMENT=production
DEBUG=false
PYTHON_VERSION=3.11.0

# Claude API Configuration (REQUIRED)
CLAUDE_API_KEY=sk-ant-your_production_api_key_here
CLAUDE_MODEL=claude-3-5-sonnet-20241022
CLAUDE_MAX_RPM=50
CLAUDE_MAX_TOKENS=4000
CLAUDE_MAX_RETRIES=3
CLAUDE_RETRY_DELAY=1.0
CLAUDE_DEMO_MODE=false

# Database Configuration (Auto-configured by Render.com)
DATABASE_URL=${DATABASE_URL}  # Automatically set by Render PostgreSQL
REDIS_URL=${REDIS_URL}        # Automatically set by Render Redis

# Vector Database Configuration
VECTOR_SERVICE_TYPE=qdrant
QDRANT_URL=https://your-cluster.qdrant.io:6333  # Qdrant Cloud URL
QDRANT_API_KEY=your_qdrant_api_key_here         # Optional: Qdrant Cloud API Key

# CORS Configuration
CORS_ORIGINS=https://examcraft-frontend.onrender.com,https://examcraft.yourdomain.com
FRONTEND_URL=https://examcraft-frontend.onrender.com

# Security
SECRET_KEY=your_production_secret_key_change_this_to_random_string

# ============================================
# FRONTEND CONFIGURATION
# ============================================

# Node Configuration
NODE_VERSION=18.18.0
NODE_ENV=production

# API Configuration
REACT_APP_API_URL=https://examcraft-backend.onrender.com
REACT_APP_ENVIRONMENT=production

# ============================================
# OPTIONAL: MONITORING & LOGGING
# ============================================

# Sentry (Error Tracking)
# SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id

# LogDNA / Datadog (Logging)
# LOGDNA_KEY=your_logdna_key
# DATADOG_API_KEY=your_datadog_key

# ============================================
# RENDER.COM SPECIFIC
# ============================================

# These are automatically set by Render.com:
# PORT - The port your service should listen on
# RENDER - Set to "true" when running on Render
# RENDER_SERVICE_NAME - Name of your service
# RENDER_INSTANCE_ID - Unique ID for the instance
# RENDER_GIT_COMMIT - Git commit SHA of the deployed code
# RENDER_GIT_BRANCH - Git branch of the deployed code

# ============================================
# NOTES
# ============================================

# 1. Never commit this file with real secrets!
# 2. Use Render.com Dashboard to set environment variables
# 3. Database URLs are automatically injected by Render.com
# 4. For Qdrant, use Qdrant Cloud or deploy as separate service
# 5. CORS_ORIGINS should match your actual frontend URL

