# Sentry Configuration
# Get your DSN from: https://talent-factory.sentry.io/settings/projects/examcraft-backend/keys/
SENTRY_DSN=https://YOUR_SENTRY_DSN@o4509606849019904.ingest.de.sentry.io/YOUR_PROJECT_ID

# Environment (development, staging, production)
ENVIRONMENT=development

# App Version (for Release Tracking)
APP_VERSION=1.0.0-dev

# Database Configuration
DATABASE_URL=postgresql://user:password@localhost:5432/examcraft

# Redis Configuration
REDIS_URL=redis://localhost:6379/0

# Claude API
ANTHROPIC_API_KEY=your_api_key_here

# Feature Flags
ENABLE_SENTRY=false

# Stripe Payment Configuration
STRIPE_SECRET_KEY=<YOUR_STRIPE_SECRET_KEY>
STRIPE_WEBHOOK_SECRET=<YOUR_STRIPE_WEBHOOK_SECRET>
STRIPE_PRICE_STARTER=price_your_starter_price_id
STRIPE_PRICE_PROFESSIONAL=price_your_professional_price_id
STRIPE_PRICE_ENTERPRISE=price_your_enterprise_price_id
FRONTEND_URL=http://localhost:3000
# ==========================================
# EMAIL CONFIGURATION (Resend)
# ==========================================
# Resend API Key - Get from: https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxx

# Default sender email (must be from verified domain)
RESEND_FROM_EMAIL=noreply@examcraft.ai

# Webhook signing secret - Get from: https://resend.com/webhooks
# Used to verify webhook authenticity
RESEND_WEBHOOK_SECRET=<YOUR_RESEND_WEBHOOK_SECRET>
